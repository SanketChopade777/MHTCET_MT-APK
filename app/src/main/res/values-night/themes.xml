<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MHTCETMT" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/purple_700</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <!-- Dark mode colors -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorSecondary">@color/purple_200</item>
        <item name="android:background">#121212</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">#B3FFFFFF</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyleDark</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyleDark</item>
        <item name="buttonBarNeutralButtonStyle">@style/NeutralButtonStyleDark</item>
    </style>

    <style name="PositiveButtonStyleDark" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/purple_200</item>
    </style>

    <style name="NegativeButtonStyleDark" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#B3FFFFFF</item>
    </style>

    <style name="NeutralButtonStyleDark" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/purple_200</item>
    </style>
</resources>